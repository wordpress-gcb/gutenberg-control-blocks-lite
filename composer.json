{
    "name": "gcb-lite/plugin",
    "description": "WordPress as a typed-field CMS for a React frontend. One component renders the editor preview and the public site.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "//": "Workspace sibling until wordpress-gcb/fields is on Packagist; then drop this and use the version constraint alone.",
            "type": "path",
            "url": "../php-sdk"
        }
    ],
    "require": {
        "php": ">=7.4",
        "wordpress-gcb/fields": "^0.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "GCBLite\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GCBLite\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --bootstrap tests/php/bootstrap-integration.php --testsuite=integration",
        "install-wp-tests": "bash bin/install-wp-tests.sh"
    },
    "config": {
        "optimize-autoloader": true
    }
}

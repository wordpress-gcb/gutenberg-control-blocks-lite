# Dependencies (restored via npm install / composer install)
node_modules/
vendor/

# Compiled / built output
build/

# Release zips (built by build-release.sh, shipped via wp.org SVN)
dist/
# But DO ship the Playground demo zip — Playground fetches it over CORS
# from raw.githubusercontent.com and GitHub release URLs don't send CORS
# headers, so this lives in the repo.
!playground/dist/

# Environment & local config
.env
.env.local
.env.*.local
# But DO ship the example template
!.env.local.example

# Local tooling state (Claude Code, etc.)
.claude/

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs / caches
*.log
npm-debug.log*
.eslintcache
.cache/
.phpunit.result.cache

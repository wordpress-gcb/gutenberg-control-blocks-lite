{
  "controls": [
    { "id": "panel", "type": "group", "label": "Header", "controlsGroup": "settings" },

    { "id": "ctrl_heading", "type": "text",     "label": "Heading",
      "attributeKey": "heading", "default": "Why this matters",
      "controlsGroup": "settings", "parentPanelId": "panel" },

    { "id": "ctrl_intro",   "type": "textarea", "label": "Intro",
      "attributeKey": "intro",

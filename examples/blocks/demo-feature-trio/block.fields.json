      "controlsGroup": "settings", "parentPanelId": "panel" }
  ],
  "allowed_blocks": ["gcb/demo-feature-item"],
  "child_constraints": {
    "defaultChildren": 3,
    "minChildren": 1,
    "addButtonLabel": "Add feature"
  }

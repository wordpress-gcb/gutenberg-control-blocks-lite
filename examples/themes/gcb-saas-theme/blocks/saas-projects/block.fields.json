{
	"controls": [
		{ "id": "panel_heading", "type": "group", "label": "Section heading" },

		{ "id": "ctrl_heading",
		  "type": "heading-level",
		  "label": "Heading",
		  "attributeKey": "heading",
		  "default": { "text": "Selected projects", "level": "h2" },
		  "levels": ["h2", "h3"],
		  "parentPanelId": "panel_heading" },

		{ "id": "ctrl_intro",
		  "type": "textarea",
		  "label": "Intro",
		  "attributeKey": "intro",
		  "validation": { "maxLength": 240 },
		  "parentPanelId": "panel_heading" },

		{ "id": "panel_query", "type": "group", "label": "Which projects" },

		{ "id": "ctrl_source",
		  "type": "toggle-group",
		  "label": "Source",
		  "attributeKey": "source",
		  "default": "latest",
		  "options": [
		    { "value": "latest", "label": "Latest" },
		    { "value": "manual", "label": "Pick" }
		  ],
		  "parentPanelId": "panel_query" },

		{ "id": "ctrl_count",
		  "type": "number",
		  "label": "Count",
		  "attributeKey": "count",
		  "default": 6,
		  "validation": { "min": 1, "max": 24 },
		  "conditionalLogic": {
		    "enabled": true,
		    "rules": [{ "field": "source", "operator": "==", "value": "latest" }]
		  },
		  "parentPanelId": "panel_query" },

		{ "id": "ctrl_post_ids",
		  "type": "post-object",
		  "label": "Projects",
		  "attributeKey": "post_ids",
		  "multiple": true,
		  "postType": "project",
		  "conditionalLogic": {
		    "enabled": true,
		    "rules": [{ "field": "source", "operator": "==", "value": "manual" }]
		  },
		  "parentPanelId": "panel_query" }
	]
}

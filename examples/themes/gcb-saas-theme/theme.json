{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,

	"settings": {
		"appearanceTools": true,

		"color": {
			"palette": [
				{ "slug": "primary",     "color": "#5956E9", "name": "Primary" },
				{ "slug": "blue-shade",  "color": "#6865FF", "name": "Blue Shade" },
				{ "slug": "link",        "color": "#2522BA", "name": "Link" },
				{ "slug": "accent-1",    "color": "#FFDC60", "name": "Accent 1 (Yellow)" },
				{ "slug": "accent-2",    "color": "#FAB8C4", "name": "Accent 2 (Pink)" },
				{ "slug": "rose",        "color": "#C75C6F", "name": "Rose" },
				{ "slug": "mabel",       "color": "#DBF8FF", "name": "Mabel" },
				{ "slug": "fog",         "color": "#DBDEFF", "name": "Fog" },
				{ "slug": "peach",       "color": "#FFEDDC", "name": "Peach" },
				{ "slug": "white",       "color": "#FFFFFF", "name": "White" },
				{ "slug": "light",       "color": "#ECF2F6", "name": "Light" },
				{ "slug": "mercury",     "color": "#E5E5E5", "name": "Mercury" },
				{ "slug": "ghost",       "color": "#C7C7D5", "name": "Ghost" },
				{ "slug": "gray-1",      "color": "#757589", "name": "Gray 1" },
				{ "slug": "gray-2",      "color": "#999FAE", "name": "Gray 2" },
				{ "slug": "ship-gray",   "color": "#42424A", "name": "Ship Gray" },
				{ "slug": "body",        "color": "#525260", "name": "Body Text" },
				{ "slug": "text-dark",   "color": "#292930", "name": "Text Dark" },
				{ "slug": "dark",        "color": "#27272E", "name": "Dark" },
				{ "slug": "black",       "color": "#000000", "name": "Black" }
			],

			"gradients": [
				{ "slug": "primary",   "name": "Primary fade",  "gradient": "linear-gradient(90deg, #ECF2F6 0%, rgba(236, 242, 246, 0) 70.31%)" },
				{ "slug": "blue",      "name": "Blue diagonal", "gradient": "linear-gradient(145.92deg, #5956E9 20.18%, #9991FF 76.9%)" },
				{ "slug": "accent",    "name": "Accent (pink)", "gradient": "linear-gradient(180deg, #FAB8C4 0%, #FFEDF0 100%)" },
				{ "slug": "dark",      "name": "Dark",          "gradient": "linear-gradient(180deg, #27272E 0%, #303035 100%)" }
			],

			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customGradient": true,
			"link": true
		},

		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "primary",
					"name": "DM Sans (body)",
					"fontFamily": "'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
				},
				{
					"slug": "secondary",
					"name": "Poppins (headings)",
					"fontFamily": "'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
				}
			],

			"fontSizes": [
				{ "slug": "body-small",  "name": "Body small",  "size": "12px" },
				{ "slug": "body",        "name": "Body",        "size": "16px" },
				{ "slug": "body-large",  "name": "Body large",  "size": "18px" },
				{ "slug": "h6",          "name": "Heading 6",   "size": "20px" },
				{ "slug": "h5",          "name": "Heading 5",   "size": "24px" },
				{ "slug": "h4",          "name": "Heading 4",   "size": "32px" },
				{ "slug": "h3",          "name": "Heading 3",   "size": "48px" },
				{ "slug": "h2",          "name": "Heading 2",   "size": "64px" },
				{ "slug": "h1",          "name": "Heading 1 (display)", "size": "80px" }
			]
		},

		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingScale": {
				"theme": [
					{ "slug": "20", "size": "0.25rem", "name": "1" },
					{ "slug": "30", "size": "0.5rem",  "name": "2" },
					{ "slug": "40", "size": "1rem",    "name": "3" },
					{ "slug": "50", "size": "1.5rem",  "name": "4" },
					{ "slug": "60", "size": "2rem",    "name": "5" },
					{ "slug": "70", "size": "3rem",    "name": "6" },
					{ "slug": "80", "size": "4rem",    "name": "7" }
				]
			}
		},

		"layout": {
			"contentSize": "768px",
			"wideSize":    "1200px"
		}
	},

	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text":       "var(--wp--preset--color--body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"fontSize":   "var(--wp--preset--font-size--body)",
			"lineHeight": "1.5"
		},
		"elements": {
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h1)", "lineHeight": "1.1" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h2)", "lineHeight": "1.1" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h3)", "lineHeight": "1.2" } },
			"h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h4)", "lineHeight": "1.2" } },
			"h5": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h5)", "lineHeight": "1.3" } },
			"h6": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--h6)", "lineHeight": "1.3" } },
			"link": { "color": { "text": "var(--wp--preset--color--link)" } }
		}
	}
}
